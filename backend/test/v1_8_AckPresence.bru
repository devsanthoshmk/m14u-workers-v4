meta {
  name: V1 ACK Presence
  type: http
  seq: 21
}

post {
  url: {{baseUrl}}/api/v1/rooms/{{roomCode}}/ack
  body: json
  auth: none
}

body:json {
  {
    "peerId": "{{hostPeerId}}",
    "eventId": "evt-test-bruno"
  }
}

script:post-response {
  test("ack status is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("ack response contract", function () {
    const body = res.getBody();
    expect(body).to.have.property("message");
    expect(body.message).to.equal("ACK accepted");
    expect(body.peerId).to.equal(bru.getEnvVar("hostPeerId"));
    expect(body.eventId).to.equal("evt-test-bruno");
  });
}
