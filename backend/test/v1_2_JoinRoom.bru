meta {
  name: V1 Join Room
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/api/v1/rooms/{{roomCode}}/join
  body: json
  auth: none
}

body:json {
  {
    "displayName": "V1 Member"
  }
}

script:post-response {
  if(res.status === 200) {
    bru.setEnvVar("memberPeerId", res.body.peerId);
  }
}
